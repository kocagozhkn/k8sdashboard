# cortex-qa-aks için Canlı API tabanı (topology Ingress üzerinden, örnek):
# VITE_K8S_API_CORTEX_QA_AKS=https://k8s-topology-qa.internal.example/k8s-api

VITE_K8S_API_CORTEX_QA_AKS=

# Sunucu (server/index.mjs): SQLite kullanıcılar. Yerelde: npm run server:dev + vite (veya npm run dev:full)
# SQLITE_PATH=data/auth.db
# SESSION_SECRET=uzun-rastgele-dize
# ALLOW_SIGNUP=0    # Yeni kayıt kapat (ilk kullanıcı yoksa açık kalır)
# AUTH_DISABLED=1   # Giriş tamamen kapalı (geliştirme)
# COOKIE_SECURE=1   # HTTPS arkasında
