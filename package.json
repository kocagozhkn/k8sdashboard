{
  "name": "k8s-topology",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "postbuild": "node scripts/git-push-after-build.mjs",
    "build:watch": "vite build --watch",
    "release": "bash scripts/deploy-acr-rollout.sh",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{js,jsx}\" \"*.{js,jsx}\""
  },
  "dependencies": {
    "d3": "^7.9.0",
    "js-yaml": "^4.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "vite": "^5.4.2",
    "vitest": "^4.1.1"
  }
}
