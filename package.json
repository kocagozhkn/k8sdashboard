{
  "name": "k8s-topology",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "server:dev": "PORT=3333 node server/index.mjs",
    "dev:full": "concurrently -k -n server,web -c blue,green \"npm run server:dev\" \"vite\"",
    "start": "node server/index.mjs",
    "build": "vite build",
    "postbuild": "node scripts/git-push-after-build.mjs",
    "build:watch": "vite build --watch",
    "release": "bash scripts/deploy-acr-rollout.sh",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{js,jsx}\" \"*.{js,jsx}\""
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "d3": "^7.9.0",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "http-proxy-middleware": "^3.0.3",
    "jszip": "^3.10.1",
    "jspdf": "^3.0.3",
    "js-yaml": "^4.1.1",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.1.2",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "vite": "^5.4.2",
    "vitest": "^4.1.1"
  }
}
